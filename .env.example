# Creator Revenue Aggregator — Environment Variables

# -----------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------
NODE_ENV=development

# Database (PostgreSQL)
DB_URL=postgresql://postgres:password@localhost:5432/creator_revenue

# Redis (BullMQ + Redlock distributed locking)
REDIS_URL=redis://localhost:6379

# Application secret (JWT signing, ≥16 chars)
APP_SECRET=change-me-to-a-long-random-secret-value

# AES-256-GCM encryption key for OAuth tokens at rest (exactly 32 chars)
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# JWT token expiry (seconds)
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# -----------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------
OAUTH_REDIRECT_BASE_URL=https://yourapp.com
OAUTH_STATE_TTL_MS=600000

# YouTube / Google
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Patreon
PATREON_CLIENT_ID=your-patreon-client-id
PATREON_CLIENT_SECRET=your-patreon-client-secret

# Gumroad
GUMROAD_CLIENT_ID=your-gumroad-client-id
GUMROAD_CLIENT_SECRET=your-gumroad-client-secret

# Substack (OAuth credentials — data ingestion uses CSV import fallback)
SUBSTACK_CLIENT_ID=your-substack-client-id
SUBSTACK_CLIENT_SECRET=your-substack-client-secret

# Shopify
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# Stripe Connect
STRIPE_CLIENT_ID=ca_your-stripe-connect-client-id
STRIPE_CLIENT_SECRET=sk_your-stripe-secret-key

# QuickBooks Online (sandbox credentials available via developer.intuit.com)
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret

# -----------------------------------------------------------------------
# AWS — S3 Raw Response Archival (US-102 compliance)
# -----------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_S3_RAW_RESPONSE_BUCKET=your-raw-api-responses-bucket

# AWS credentials (use IAM role in production — these are for local dev only)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# -----------------------------------------------------------------------
# Runtime / process topology
# -----------------------------------------------------------------------
# Which subsystems this process runs. One of: api | worker | scheduler | all
# Local dev uses "all" for a single bootable process.
PROCESS_ROLE=all

# HTTP health endpoint port (used when role ∈ {api, all})
API_PORT=3000

# Graceful shutdown budget (ms). SIGTERM/SIGINT unwinds everything within this.
SHUTDOWN_TIMEOUT_MS=15000

# -----------------------------------------------------------------------
# PostgreSQL pool
# -----------------------------------------------------------------------
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000
# Set true for managed Postgres that requires TLS (RDS, Supabase, etc.)
DB_SSL=false

# -----------------------------------------------------------------------
# BullMQ workers + queues
# -----------------------------------------------------------------------
WORKER_CONCURRENCY=4
INGESTION_QUEUE_NAME=ingestion
MAINTENANCE_QUEUE_NAME=maintenance

# -----------------------------------------------------------------------
# Scheduler (BullMQ repeatable jobs)
# -----------------------------------------------------------------------
SCHEDULER_ENABLED=true
# Nightly ingestion fan-out — US-102 requires 2 AM UTC
NIGHTLY_INGESTION_CRON=0 2 * * *
# OAuth token health monitor (US-901 plumbing)
TOKEN_HEALTH_CRON=0 6 * * *

